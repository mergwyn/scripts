#!/usr/bin/env bash

# shellcheck source=/dev/null
for function in "$(dirname "$0")"/../functions/*.sh; do source "${function}"; done

cmd=$1
me=$(basename "$0")
export KOPIA_CHECK_FOR_UPDATES=false

# --- Environment Setup ---
case $(uname) in
  Linux)  topdir=~/.config/kopia;;
  Darwin) topdir="~/Library/Application Support/kopia";;
  *)      log_error "Unknown OS"; exit 1;;
esac
config_dir=${topdir}
[[ -d ${topdir} ]] || mkdir -p ${topdir}

# Load BWS Token (suggested path for your roll-out)
[[ -f "/etc/kopia/.bws_env" ]] && source "/etc/kopia/.bws_env"
[[ -z "${BWS_ACCESS_TOKEN}" ]] && { log_error "BWS_ACCESS_TOKEN not set"; exit 1; }

# --- UUID Configuration ---
declare -A STORE_UUIDS=(
    [idrivee2]="31c6c57d-7a0d-4e3c-afaf-b1ec01031b4f"
    [minio]="232cb3fe-cf1d-493b-b879-b1ec00fe24c5"
    [repo-pw]="500f90e6-0977-40e9-a425-b42100fe869a"
)

# --- Secret Helper ---
load_bws_s3() {
    local store=$1
    local uuid=${STORE_UUIDS[$store]}
    [[ -z "$uuid" ]] && { log_error "No UUID for $store"; return 1; }

    local raw
    raw=$(bws secret get "$uuid" --output json | jq -r '.value')

    # Parses "KEY: VALUE" format from BWS into exports
    while IFS= read -r line; do
        [[ $line == *:* ]] || continue
        # Extract key and value, trimming whitespace
        local k=$(echo "${line%%:*}" | xargs)
        local v=$(echo "${line#*:}" | xargs)
        export "$k"="$v"
    done <<< "$raw"

    # TLS logic: Strict check for minio or internal port 9000
    TLS_FLAG=""
    if [[ "$store" == "minio" ]] || [[ "$ENDPOINT" == *":9000"* ]]; then
        log_debug "Disabling TLS for $store ($ENDPOINT)"
        TLS_FLAG="--disable-tls"
    fi
}

# Load the password (the one Velero is also using)
KOPIA_PASSWORD=$(bws secret get "${STORE_UUIDS[repo-pw]}" --output json | jq -r '.value')

# --- Main Repo Logic ---
connect_repo() {
    local type=$1
    local bucket="kopia"
    local prefix=""

    if [[ $type == velero-* ]]; then
        local stem=${type#velero-}
        local store=${stem%%-*}
        local ns=${type#velero-*-}
        bucket="velero"
        prefix="kopia/${ns}/"
    else
        local store=${type#kopia-}
    fi

    load_bws_s3 "$store" || return 1

    log_info "Connecting: ${type} -> ${ENDPOINT} [Bucket: ${bucket}]"
    
    kopia repository connect s3 ${TLS_FLAG} \
        --endpoint="${ENDPOINT}" \
        --bucket="${bucket}" \
        --prefix="${prefix}" \
        --access-key="${ACCESS_KEY_ID}" \
        --secret-access-key="${SECRET_ACCESS_KEY}" \
        --password="${KOPIA_PASSWORD}" \
        --config-file="${config_dir}/${type}.config" \
        --enable-actions \
        --description="BWS Managed: ${type}"

    export KOPIA_CONFIG_PATH="${config_dir}/${type}.config"
}

global_policy() {
    local type=$1
    connect_repo "$type" || exit 1
    
    # Your original run-parts action hooks
    local action_base="/bin/run-parts --report /etc/kopia"
    
    log_info "Setting global policy for ${type}..."
    kopia policy set --global \
        --compression=zstd \
        --keep-latest=0 --keep-hourly=24 --keep-daily=7 --keep-weekly=4 --keep-monthly=12 --keep-annual=0 \
        --ignore-identical-snapshots=false --ignore-unknown-types=true \
        --before-folder-action="${action_base}/folder-before" \
        --after-folder-action="${action_base}/folder-after" \
        --before-snapshot-root-action="${action_base}/snap-before" \
        --after-snapshot-root-action="${action_base}/snap-after"
}

# --- Command Switch ---
case ${cmd} in
  repo)
    sub=$2; type=$3
    case ${sub} in
      connect) connect_repo "$type" ;;
      create)  
        [[ $type == kopia-* ]] || { log_error "Velero repos are connect-only"; exit 1; }
        load_bws_s3 "${type#kopia-}"
        kopia repository create s3 ${TLS_FLAG} --endpoint="${ENDPOINT}" --bucket="kopia" \
            --access-key="${ACCESS_KEY_ID}" --secret-access-key="${SECRET_ACCESS_KEY}" \
            --password="${KOPIA_PASSWORD}" --config-file="${config_dir}/${type}.config"
        ;;
      list) ls "${config_dir}"/*.config 2>/dev/null | sed 's/\.config$//' ;;
    esac
    ;;
  policy) [[ $2 == "global" ]] && global_policy "$3" ;;
  system)
    if [[ $2 == "certs" ]]; then
       log_warn "Certs still require kubectl access to the cluster."
       # Insert your original create_cert logic here if still needed
    fi
    ;;
  *) usage1; exit 1 ;;
esac
